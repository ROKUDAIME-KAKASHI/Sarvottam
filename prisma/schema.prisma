// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("STUDENT") // STUDENT, FACULTY, INDUSTRY_PARTNER, SUPERADMIN
  skills        String?
  portfolioUrl  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  studentProfile  Student?
  facultyProfile  Faculty?
  industryProfile IndustryPartner?

  applications  Application[]
  notifications Notification[]
  submittedProblems Problem[] @relation("SubmittedProblems")
  assignedProblems  Problem[] @relation("AssignedProblems")
  createdProjects   Project[] @relation("ProjectCreator")
  impersonationTokens ImpersonationToken[]
}

model Department {
  id          String    @id @default(cuid())
  name        String
  description String?
  projects    Project[]
  faculties   Faculty[]
}

model Student {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills     String? // Comma-separated or JSON string
  portfolio  String?
}

model Faculty {
  id           String     @id @default(cuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  mentoredProjects Project[]
}

model IndustryPartner {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  sector      String
  projects    Project[]
}

model Project {
  id               String           @id @default(cuid())
  title            String
  description      String
  difficultyLevel  String?
  duration         String?
  status           String           @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  departmentId     String?
  department       Department?       @relation(fields: [departmentId], references: [id])
  mentorId         String?
  mentor           Faculty?         @relation(fields: [mentorId], references: [id])
  partnerId        String?
  partner          IndustryPartner? @relation(fields: [partnerId], references: [id])
  creatorId        String?
  creator          User?            @relation("ProjectCreator", fields: [creatorId], references: [id])
  applications     Application[]
  documents        Document[]
  problems         Problem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Application {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
}

model ResearchPaper {
  id          String   @id @default(cuid())
  title       String
  abstract    String
  url         String
  authors     String
  createdAt   DateTime @default(now())
}

model Document {
  id        String   @id @default(cuid())
  name      String
  url       String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model KPI {
  id          String   @id @default(cuid())
  metricName  String
  value       Float
  date        DateTime @default(now())
}

model Report {
  id          String   @id @default(cuid())
  title       String
  createdAt   DateTime @default(now())
}

model Problem {
  id          String   @id @default(cuid())
  title       String
  description String?
  area        String   @default("PROCESS") // PEOPLE, PROCESS, TECHNOLOGY, BUSINESS, COMPLIANCE
  quadrant    String?  // DO_FIRST, SCHEDULE, DELEGATE, ELIMINATE
  status      String   @default("OPEN") // OPEN, PENDING, APPROVED, ESCALATED, RESOLVED
  level       String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  score       Float?   @default(0) // priority score
  facultyApproved Boolean @default(false)
  industryApproved Boolean @default(false)

  submitterId String
  submitter   User     @relation("SubmittedProblems", fields: [submitterId], references: [id])
  
  assigneeId  String?
  assignee    User?    @relation("AssignedProblems", fields: [assigneeId], references: [id])

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ImpersonationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
