// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("STUDENT") // SUPERADMIN, FACULTY, STUDENT, INDUSTRY_PARTNER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  studentProfile  Student?
  facultyProfile  Faculty?
  industryProfile IndustryPartner?

  applications  Application[]
  notifications Notification[]
}

model Department {
  id          String    @id @default(cuid())
  name        String
  description String?
  projects    Project[]
  faculties   Faculty[]
}

model Student {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills     String? // Comma-separated or JSON string
  portfolio  String?
}

model Faculty {
  id           String     @id @default(cuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  mentoredProjects Project[]
}

model IndustryPartner {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  sector      String
  projects    Project[]
}

model Project {
  id               String           @id @default(cuid())
  title            String
  description      String
  difficultyLevel  String?
  duration         String?
  status           String           @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  departmentId     String
  department       Department       @relation(fields: [departmentId], references: [id])
  mentorId         String?
  mentor           Faculty?         @relation(fields: [mentorId], references: [id])
  partnerId        String?
  partner          IndustryPartner? @relation(fields: [partnerId], references: [id])
  applications     Application[]
  documents        Document[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Application {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
}

model ResearchPaper {
  id          String   @id @default(cuid())
  title       String
  abstract    String
  url         String
  authors     String
  createdAt   DateTime @default(now())
}

model Document {
  id        String   @id @default(cuid())
  name      String
  url       String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model KPI {
  id          String   @id @default(cuid())
  metricName  String
  value       Float
  date        DateTime @default(now())
}

model Report {
  id          String   @id @default(cuid())
  title       String
  content     String
  createdAt   DateTime @default(now())
}
